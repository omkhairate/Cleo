CLEO_APP_NAME=Cleo
CLEO_ENV=development
CLEO_API_URL=http://127.0.0.1:8000
CLEO_ROUTING_MODE=local-only
CLEO_LOCAL_MODEL_PROVIDER=transformers-smolvlm
CLEO_LOCAL_MODEL_ID=HuggingFaceTB/SmolVLM-500M-Instruct
CLEO_LOCAL_MODEL_BASE_URL=
CLEO_LOCAL_MODEL_TIMEOUT_SECONDS=180
CLEO_ONLINE_MODEL_ENABLED=false
CLEO_ONLINE_MODEL_PROVIDER=openai-compatible
CLEO_ONLINE_MODEL_ID=gpt-4.1-mini
CLEO_ONLINE_MODEL_BASE_URL=https://api.openai.com/v1
CLEO_ONLINE_MODEL_API_KEY=
CLEO_ONLINE_MODEL_TIMEOUT_SECONDS=120
# Hugging Face experiment path:
# CLEO_ONLINE_MODEL_ENABLED=true
# CLEO_ONLINE_MODEL_PROVIDER=huggingface
# CLEO_ONLINE_MODEL_ID=CohereLabs/command-a-vision-07-2025:cohere
# CLEO_ONLINE_MODEL_BASE_URL=https://router.huggingface.co/v1
# CLEO_ONLINE_MODEL_API_KEY=hf_your_token_here
CLEO_API_TIMEOUT_SECONDS=180
CLEO_CONVERSATION_HISTORY_LIMIT=12
CLEO_STATE_FILE_PATH=.cleo/state.json
CLEO_ARGUS_ENABLED=true
CLEO_ARGUS_BASE_URL=http://127.0.0.1:8010
CLEO_ARGUS_TIMEOUT_SECONDS=60
